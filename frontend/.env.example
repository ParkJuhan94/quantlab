VITE_API_BASE_URL=http://localhost:8080

# OAuth 클라이언트 ID(공개값 - 시크릿은 백엔드 .env에만 존재).
# 리다이렉트 URI는 코드에서 window.location.origin 기준으로 동적 생성하므로
# 여기엔 없음 - 백엔드 .env의 GOOGLE_REDIRECT_URI 등과 정확히 일치해야
# 하므로 프론트 개발 서버 포트(3001)를 임의로 바꾸지 말 것.
VITE_GOOGLE_CLIENT_ID=your_google_client_id
VITE_KAKAO_CLIENT_ID=your_kakao_client_id
VITE_NAVER_CLIENT_ID=your_naver_client_id
