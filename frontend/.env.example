VITE_API_BASE_URL=http://localhost:8080

# OAuth 클라이언트 ID(공개값 - 시크릿은 백엔드 .env에만 존재).
# 리다이렉트 URI는 코드에서 window.location.origin 기준으로 동적 생성해
# 백엔드로 넘기므로 여기엔 없음 - 대신 각 프로바이더 콘솔에 등록된
# Authorized Redirect URI와 정확히 일치해야 하므로 프론트 개발 서버
# 포트(3001)를 임의로 바꾸지 말 것.
VITE_GOOGLE_CLIENT_ID=your_google_client_id
VITE_KAKAO_CLIENT_ID=your_kakao_client_id
VITE_NAVER_CLIENT_ID=your_naver_client_id

# 토스페이먼츠 결제위젯 클라이언트 키(공개값 - 시크릿키는 백엔드 .env에만
# 존재). 사업자등록 전에는 토스페이먼츠 개발자센터에서 발급되는 테스트
# 클라이언트 키만 사용 가능.
VITE_TOSS_PAYMENTS_CLIENT_KEY=your_toss_payments_test_client_key
