# 프로덕션 배포용 시크릿 템플릿. 실제 파일명은 .env.prod로 저장하고
# 절대 커밋하지 않는다(.gitignore 처리됨).
#
# docker-compose.prod.yml은 ${VAR} 치환에 이 파일을 쓰기 위해 항상
# --env-file .env.prod 플래그와 함께 실행해야 한다(docker compose는
# 기본적으로 .env만 자동 로드하고 .env.prod는 명시적으로 지정해야 함).
# 자세한 실행 명령은 docs/DEPLOYMENT.md 참고.

# --- MySQL ---
DB_USER=root
DB_PASSWORD=change_this_to_a_strong_password
MYSQL_DATABASE=quantlab

# --- Toss 증권 Open API ---
TOSS_CLIENT_ID=your_client_id
TOSS_CLIENT_SECRET=your_client_secret
TOSS_BASE_URL=https://openapi.tossinvest.com
REALTIME_PRICE_POLL_INTERVAL_MS=3000

# --- 한국투자증권(KIS) Open API(해외 종목 백테스트 유니버스 연동, 선택 -
# 미설정 시 해당 기능만 비활성. KIS Developers 포털에서 계좌 개설 후
# 앱키/시크릿 발급 필요) ---
KIS_APP_KEY=your_kis_app_key
KIS_APP_SECRET=your_kis_app_secret
KIS_BASE_URL=https://openapi.koreainvestment.com:9443

# --- 네이버 금융 / TradingView(인증 불필요한 공개 API, 기본값 그대로 둬도
# 됨 - 실제로 다른 값이 필요할 일은 거의 없지만 application.yml의
# ${VAR:default} 키와 짝을 맞추기 위해 문서화) ---
NAVER_FINANCE_BASE_URL=https://m.stock.naver.com
NAVER_FINANCE_CHART_BASE_URL=https://api.stock.naver.com
TRADINGVIEW_BASE_URL=https://scanner.tradingview.com

# --- CORS(same-origin 프록시라 실질적으로 미사용에 가깝지만, 백엔드에
# 직접 접근하는 시나리오 대비 실제 서비스 도메인으로 채워둔다) ---
APP_CORS_ALLOWED_ORIGIN=https://your-domain.example.com

# --- AWS(로그 수집 오버레이 docker-compose.cloudwatch.yml, 모니터링
# scripts/report-health-metric.sh, 백업 scripts/backup-mysql.sh가 참조.
# EC2 인스턴스 프로파일(IAM Role)로 권한을 부여하므로 액세스 키는 여기
# 안 둔다 - 필요 IAM 정책은 docs/DEPLOYMENT.md 참고) ---
AWS_REGION=ap-northeast-2
BACKUP_S3_BUCKET=your-quantlab-backup-bucket

# --- JWT ---
JWT_SECRET=change_this_to_a_long_random_secret
JWT_ACCESS_TOKEN_VALIDITY=1800000
JWT_REFRESH_TOKEN_VALIDITY=1209600000

# --- OAuth(redirect_uri는 프론트가 window.location.origin 기준으로
# 런타임에 동적 생성해 백엔드로 넘기므로 여기엔 없음 - 각 프로바이더
# 콘솔에 실제 서비스 도메인 기준 redirect_uri 등록만 필요.
# docs/DEPLOYMENT.md 참고) ---
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

KAKAO_CLIENT_ID=your_kakao_client_id
KAKAO_CLIENT_SECRET=your_kakao_client_secret

NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# --- 프론트 빌드 인자로 쓰이는 공개 OAuth 클라이언트 ID(시크릿 아님,
# docker-compose.prod.yml의 frontend.build.args가 참조) ---
VITE_GOOGLE_CLIENT_ID=your_google_client_id
VITE_KAKAO_CLIENT_ID=your_kakao_client_id
VITE_NAVER_CLIENT_ID=your_naver_client_id

# --- 이미지 업로드(로컬 디스크 저장, docker-compose.prod.yml의 backend
# 서비스에 마운트된 upload_data 볼륨과 짝을 이룸. UPLOAD_DIR 자체는
# 컨테이너 내부 절대경로라 시크릿이 아닌 토폴로지 값 - .env.prod가 아니라
# docker-compose.prod.yml의 environment:에 고정돼 있음, 여기서 건드릴
# 필요 없음) ---
# 업로드 이미지가 실제로 열람되는 절대 URL origin. 피드/의견 보내기
# 화면 자체는 상대경로(/uploads/...)로도 충분하지만, Slack 웹훅처럼
# 서버가 절대 URL을 만들어야 하는 소비자용(FeedbackService 참고) -
# localhost로 두면 Slack 알림의 이미지 링크가 깨지므로 반드시 실제
# 서비스 도메인으로 채울 것.
UPLOAD_PUBLIC_BASE_URL=https://your-domain.example.com
UPLOAD_MAX_SIZE_BYTES=5242880

# 사이드패널 "의견 보내기"가 전송할 Slack Incoming Webhook URL. 아래
# 모니터링 섹션의 SLACK_ALERT_WEBHOOK_URL(인프라 알람)과는 반드시 다른
# 채널로 발급받을 것 - 사용자 피드백과 인프라 알람이 같은 채널에 섞이면
# 노이즈가 커진다. 비워두면 의견 보내기 API가 명시적으로
# WEBHOOK_NOT_CONFIGURED 에러를 반환한다(조용한 실패 아님).
SLACK_FEEDBACK_WEBHOOK_URL=your_feedback_slack_incoming_webhook_url

# --- Python 퀀트 엔진(선택 - 미설정 시 규칙 기반 템플릿 코멘트로 폴백) ---
ANTHROPIC_API_KEY=your_anthropic_api_key

# --- 모니터링(docker-compose.monitoring.yml, Phase 1: 메트릭+대시보드+알림) ---
# Grafana 초기 관리자 비밀번호. 최초 로그인 후 UI에서 바꾸는 것을 권장.
GRAFANA_ADMIN_PASSWORD=change_this_to_a_strong_password
# Alertmanager가 알림을 전송할 Slack Incoming Webhook URL. 기존
# SLACK_FEEDBACK_WEBHOOK_URL(사용자 피드백 전용)과는 별도 채널로 새로
# 발급받을 것을 권장 - 인프라 알람과 사용자 피드백이 같은 채널에 섞이면
# 노이즈가 커진다. 비워두면 Alertmanager가 빈 문자열로 치환되어 Slack
# 전송이 실패하지만(설정 오류 로그만 남음), 나머지 스택(Prometheus/Grafana)
# 동작에는 영향 없다.
SLACK_ALERT_WEBHOOK_URL=your_ops_slack_incoming_webhook_url
