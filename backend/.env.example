TOSS_CLIENT_ID=your_client_id
TOSS_CLIENT_SECRET=your_client_secret
TOSS_BASE_URL=https://openapi.tossinvest.com

# 토스페이먼츠(결제/구독) - 위 TOSS_*(토스증권 시세 조회)와는 완전히 다른
# 제품/키. 사업자등록 전에는 토스페이먼츠 개발자센터에서 이메일 가입만으로
# 발급되는 테스트 키만 쓸 수 있다(실결제 불가, 사업자 심사는 라이브 키
# 발급 시에만 필요). 라이브 전환 시 이 값들만 교체하면 된다.
TOSS_PAYMENTS_CLIENT_KEY=your_toss_payments_test_client_key
TOSS_PAYMENTS_SECRET_KEY=your_toss_payments_test_secret_key
# 웹훅 서명 검증용 - 비어 있으면 검증을 건너뛴다(로컬 테스트 전용, 운영에선 필수)
TOSS_PAYMENTS_WEBHOOK_SECRET=

# 빌링키(카드 자동결제 권한 토큰) DB 컬럼 암호화 키(base64 32바이트, AES-GCM).
# 비어 있으면 평문 저장(로컬 개발 전용) - 운영 배포 전 반드시 채울 것.
# 생성 예: openssl rand -base64 32
SUBSCRIPTION_BILLING_KEY_ENCRYPTION_KEY=

# 해외 종목 백테스트 유니버스 연동용(한국투자증권 Open API, KIS Developers
# 포털에서 계좌 개설 후 앱키/시크릿 발급 필요)
KIS_APP_KEY=your_kis_app_key
KIS_APP_SECRET=your_kis_app_secret
KIS_BASE_URL=https://openapi.koreainvestment.com:9443

PYTHON_ENGINE_URL=http://localhost:8000
REALTIME_PRICE_POLL_INTERVAL_MS=3000
MARKET_RANKING_POLL_INTERVAL_MS=5000
DB_USER=root
DB_PASSWORD=quantlime
MYSQL_HOST=localhost
MYSQL_PORT=3308
MYSQL_DATABASE=quantlime
REDIS_HOST=localhost
REDIS_PORT=6381

APP_CORS_ALLOWED_ORIGIN=http://localhost:3001

JWT_SECRET=change_this_to_a_long_random_secret
JWT_ACCESS_TOKEN_VALIDITY=1800000
JWT_REFRESH_TOKEN_VALIDITY=1209600000

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

KAKAO_CLIENT_ID=your_kakao_client_id
KAKAO_CLIENT_SECRET=your_kakao_client_secret

NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# 사이드패널 "의견 보내기"가 전송할 Slack Incoming Webhook URL. 비어 있으면
# 의견 보내기 API가 명시적으로 WEBHOOK_NOT_CONFIGURED 에러를 반환한다.
SLACK_FEEDBACK_WEBHOOK_URL=
